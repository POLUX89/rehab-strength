# Copiá este archivo a .env y completá los valores. .env está en .gitignore.
#   cp .env.example .env

# --- Credenciales de Google (elegí UNA opción) -------------------------------

# Opción A (recomendada en local): ruta al JSON de la service account.
# Guardalo FUERA del repo, en ~/.config/rehab-strength/ con permisos 600.
GOOGLE_APPLICATION_CREDENTIALS=/Users/TU_USUARIO/.config/rehab-strength/service-account.json

# Opción B (CI / contenedores): el JSON entero en una sola línea.
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# En Streamlit Cloud no uses ninguna de las dos: cargá [gcp_service_account]
# en la UI de Secrets (ver .streamlit/secrets.toml.example).

# --- Fuentes de datos --------------------------------------------------------

# Nombre de la pestaña de sueño dentro de cada spreadsheet.
REHAB_SLEEP_TAB=Sleep

# Prefijo para descubrir spreadsheets en Drive. Matchea v2, v5, etc.
REHAB_HEALTH_METRICS_PREFIX=Health Metrics_v

# --- Rutas (opcionales; por defecto son relativas a la raíz del repo) --------
# REHAB_DATA_DIR=./data
# REHAB_MODELS_DIR=./models
# REHAB_REPORTS_DIR=./reports
